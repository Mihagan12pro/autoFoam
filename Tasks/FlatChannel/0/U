FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (0 0 0);
U -5;
boundaryField
{
    outlet
    {
        type            zeroGradient;
    }
    
    inlet
    {
        type            fixedValue;
        value           uniform (0 ${U} 0);
    }
    
    frontWall
    {
        type            empty;
    }
    
    backWall
    {
         type           empty;
    }
    
    sideWall
    {
        type            noSlip;
    }
}


