<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:vm="using:AutoFoam.UI.ViewModels"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="using:AutoFoam.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="450"
        x:Class="AutoFoam.UI.ErrorsWindow"
        Icon="/Assets/avalonia-logo.ico"
        Background="#BFDBFF"
        Width="450"
        Height="450"
         x:DataType="vm:ErrorsWindowViewModel"
        Title="╬°ŔßŕŔ">
        <Border 
            Margin="30"
            BorderBrush="Black" 
            BorderThickness="1">
            <ScrollViewer Margin="10">
                <ListBox Background="#BFDBFF" ItemsSource="{Binding Errors}">
                    
                </ListBox>
            </ScrollViewer>
        </Border>
</Window>
